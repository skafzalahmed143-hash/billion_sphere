{
    "name": "billion-sphere-shared",
    "version": "1.0.0",
    "description": "Shared utilities and services for Billion Sphere",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "dev": "nodemon index.js",
        "db:migrate": "sequelize-cli db:migrate --migrations-path ./database/migrations --config ./database/config.js --models-path ./database/models",
        "db:seed": "sequelize-cli db:seed:all --seeders-path ./database/seeders --config ./database/config.js --models-path ./database/models"
    },
    "dependencies": {
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "joi": "^18.0.2",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.19.0",
        "pg-hstore": "^2.3.4",
        "sequelize": "^6.37.7"
    },
    "devDependencies": {
        "nodemon": "^3.1.14",
        "sequelize-cli": "^6.6.5"
    }
}